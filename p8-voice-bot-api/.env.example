# Copy to .env and fill values as needed
OPENAI_API_KEY=sk-your-openai-key
HUGGINGFACEHUB_API_TOKEN=hf_your_hf_token
# Alternative variable name recognized:
# HF_TOKEN=

# Optional: supply a specific SpeechT5 speaker embedding (.npy or .pt)
# SPEECHT5_XVECTOR_PATH=path/to/xvector.npy

# Comma separated list or * for any
ALLOWED_ORIGINS=*

# Environment name
ENVIRONMENT=development
